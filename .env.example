# ---------------------------------------------------------------------------
# yt-tutor configuration. Copy to `.env` and fill in only what you need.
# The DEFAULT (transcript-only) path needs NO keys at all.
# Keys are only required if you turn on the vision pass (--vision / VISION_ENABLED).
# ---------------------------------------------------------------------------

# Where ingested data lives (db + frames). Defaults to ./data in the current dir.
# YT_TUTOR_DATA_DIR=./data

# --- Vision pass (per-keyframe analysis at ingest time) -------------------
# Provider for analyzing keyframes. One of: anthropic | openai | gemini | ollama
VISION_PROVIDER=anthropic
# Turn the (paid) vision pass on/off by default. CLI flags --vision/--no-vision win.
VISION_ENABLED=false

# --- API keys (set only the provider you actually use) --------------------
# NOTE: an Anthropic *Max/Pro* subscription does NOT include API access.
#       The vision pass uses the pay-per-use Anthropic API and needs a real key.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Model overrides (sensible defaults are baked in; override if you like) -
# ANTHROPIC_VISION_MODEL=claude-haiku-4-5-20251001
# OPENAI_VISION_MODEL=gpt-4o-mini
# GEMINI_VISION_MODEL=gemini-2.0-flash
# OLLAMA_VISION_MODEL=llava
# OLLAMA_HOST=http://localhost:11434

# --- Transcription fallback (only runs when a video has no captions) -------
# Requires:  pip install "yt-tutor[whisper]"
# WHISPER_MODEL=base          # tiny | base | small | medium | large-v3
# WHISPER_DEVICE=cpu          # cpu | cuda
